  return Object.entries(AGENT_ROLES).map(([role, config]) => ({
    role,
    label: config.label,
    title: config.title,
    ixTypes: config.ixTypes,
    maxEntries: config.maxEntries,
    priorityChains: config.priorityChains,
    permissions: config.permissions
