  }));
}

// ---------------------------------------------------------------------------
// IX Cache Management
// ---------------------------------------------------------------------------

function invalidateIxCache() {
  ixCache.clear();
  _lastIxInvalidation = Date.now();
}

function startIxFileWatcher() {
  if (_ixFileWatcher) return; // already watching
  const watchDir = path.join(projectRoot, "data", "agent-index");
  try {
    _ixFileWatcher = fs.watch(watchDir, { recursive: true }, () => {
      // Debounce rapid-fire events (500ms)
      if (_ixWatcherDebounceTimer) clearTimeout(_ixWatcherDebounceTimer);
      _ixWatcherDebounceTimer = setTimeout(() => {
        invalidateIxCache();
        _ixWatcherDebounceTimer = null;
      }, 500);
    });
    _ixFileWatcher.on("error", (err) => {
      console.error("[spawnContextBuilder] fs.watch error on agent-index:", err.message);
      // Clean up so startIxFileWatcher can be retried
      try { _ixFileWatcher.close(); } catch (_) {}
      _ixFileWatcher = null;
    });
  } catch (err) {
    console.error("[spawnContextBuilder] Failed to start fs.watch on agent-index:", err.message);
    _ixFileWatcher = null;
  }
}

function stopIxFileWatcher() {
  if (_ixWatcherDebounceTimer) {
    clearTimeout(_ixWatcherDebounceTimer);
    _ixWatcherDebounceTimer = null;
  }
  if (_ixFileWatcher) {
    try { _ixFileWatcher.close(); } catch (_) {}
    _ixFileWatcher = null;
  }
}

function getIxCacheStats() {
  const cachedRoles = [];
  let totalCachedEntries = 0;
  for (const [role, data] of ixCache) {
    cachedRoles.push(role);
    totalCachedEntries += data.entries.length;
  }
  return {
    cachedRoles,
    totalCachedEntries,
    lastInvalidation: _lastIxInvalidation,
    watcherActive: _ixFileWatcher !== null
  };
}

