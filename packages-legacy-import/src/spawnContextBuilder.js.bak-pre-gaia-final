// Liris's structured health-state.json reader (primary)
function readHealthState() {
  try {
    if (fs.existsSync(HEALTH_PATH)) {
      const raw = JSON.parse(fs.readFileSync(HEALTH_PATH, "utf8"));
      return {
        status: String(raw.status || "unknown"),
        blockers: Array.isArray(raw.blockers) ? raw.blockers : [],
        checkedAt: raw.checkedAt || null,
        services: raw.services || {}
      };
    }
  } catch (_) { /* fall through to flag-file check */ }

  // Gaia fallback: flag-file based health check
  const blockers = [];
  const healthFlag = path.join(projectRoot, "runtime", "flags", "health-ok.flag");
  if (fs.existsSync(path.join(projectRoot, "runtime", "flags")) && !fs.existsSync(healthFlag)) {
    blockers.push("health-ok.flag absent");
  }
  return { status: blockers.length > 0 ? "degraded" : "unknown", blockers, checkedAt: null, services: {} };
}

// Gaia's admin terminal blocker check (supplements health state)
function getCurrentBlockers() {
  const blockers = [];

  // Check admin terminal status files
  for (const terminal of ["helm", "sentinel"]) {
    const statusPath = path.join(ADMIN_TERMINALS, terminal, "status.json");
    try {
      if (fs.existsSync(statusPath)) {
        const status = JSON.parse(fs.readFileSync(statusPath, "utf8"));
        if (status.state === "error" || status.state === "crashed") {
          blockers.push({ source: `admin-terminal/${terminal}`, state: status.state, detail: status.lastError || "" });
        }
      }
    } catch (_) { /* skip */ }
  }

  return blockers;
}

// ---------------------------------------------------------------------------
// I — Integral: IX Knowledge Filtered by Role
// ---------------------------------------------------------------------------

function getIxEntriesForRole(role) {
  const config = AGENT_ROLES[role];
  if (!config) return [];

  // Check cache first
  const cached = ixCache.get(role);
  if (cached && Date.now() < cached.validUntil) {
    return cached.entries.slice(); // return copy so callers can mutate safely
  }

  const entries = [];

  // First: priority chain entries (highest value) — Gaia-specific
  if (config.priorityChains) {
    for (const ixRef of config.priorityChains) {
      const result = searchAgentIndex(ixRef, { limit: 1, force: true });
      if (result.matches && result.matches.length > 0) {
        entries.push(result.matches[0]);
      }
    }
  }

  // Second: type-filtered entries from IX folders
  for (const ixType of config.ixTypes) {
    const result = searchAgentIndex(ixType, { limit: 4 });
    if (result.matches) {
      for (const match of result.matches) {
        if (!entries.some(e => e.ix === match.ix)) {
          entries.push(match);
        }
      }
    }
  }

  // Boot-critical if needed — Gaia-specific
  if (config.includeBootCritical) {
    for (const bootIx of ["IX-309", "IX-308", "IX-310", "IX-311"]) {
      if (!entries.some(e => e.ix === bootIx)) {
        const result = searchAgentIndex(bootIx, { limit: 1 });
        if (result.matches && result.matches.length > 0) {
          entries.push(result.matches[0]);
        }
      }
    }
  }

  // Deduplicate and cap
  const seen = new Set();
  const result = entries.filter(e => {
    if (seen.has(e.ix)) return false;
    seen.add(e.ix);
    return true;
  }).slice(0, config.maxEntries);

  // Cache the result
  const now = Date.now();
  ixCache.set(role, {
    entries: result,
    cachedAt: now,
    validUntil: now + IX_CACHE_TTL_MS
  });

  return result;
}

// ---------------------------------------------------------------------------
// D — Derivative: Recent Signals
// ---------------------------------------------------------------------------

// Liris's structured drift-signals.json reader (primary)
function readDriftSignals() {
  try {
    if (fs.existsSync(DRIFT_PATH)) {
      const raw = JSON.parse(fs.readFileSync(DRIFT_PATH, "utf8"));
      return {
        signals: Array.isArray(raw.signals) ? raw.signals.slice(-10) : [],
        lastUpdate: raw.lastUpdate || null,
        mqttTraffic: raw.mqttTraffic || null,
        inboxDelta: raw.inboxDelta || 0
      };
    }
  } catch (_) { /* fall through to inbox mtime check */ }

  // Gaia fallback: inbox mtime-based signal detection
  const signals = [];
  const inboxes = [
    { name: "gaia", path: path.join(projectRoot, "runtime", "gaia-inbox.ndjson") },
    { name: "dasein", path: path.join(projectRoot, "runtime", "dasein-inbox.ndjson") },
    { name: "helm", path: path.join(ADMIN_TERMINALS, "helm", "inbox.ndjson") }
  ];

  for (const inbox of inboxes) {
    try {
      if (fs.existsSync(inbox.path)) {
        const stat = fs.statSync(inbox.path);
        const ageMs = Date.now() - stat.mtimeMs;
        if (ageMs < 300000) { // Modified in last 5 minutes
          signals.push({ source: `inbox/${inbox.name}`, age: `${Math.round(ageMs / 1000)}s ago`, type: "recent-message" });
        }
      }
    } catch (_) { /* skip */ }
  }

  return { signals, lastUpdate: null, mqttTraffic: null, inboxDelta: 0 };
}

// ---------------------------------------------------------------------------
// Mistake Filter — role-relevant mistakes from the pattern store (from Liris)
// ---------------------------------------------------------------------------

function getMistakesForRole(role) {
  if (!listMistakePatterns) return [];
  try {
    const all = listMistakePatterns({ limit: 50 });
    if (!Array.isArray(all) || all.length === 0) return [];

    const config = AGENT_ROLES[role];
    if (!config) return [];

    // Filter by tag overlap with role's IX types and permissions
    const roleKeywords = [
      role,
      ...config.ixTypes,
      ...(config.permissions || []).map((p) => p.split(".")[0])
    ];

    return all
      .filter((m) => {
        const tags = Array.isArray(m.tags) ? m.tags : [];
        const name = String(m.name || m.id || "").toLowerCase();
        return roleKeywords.some((kw) =>
          tags.some((t) => String(t).toLowerCase().includes(kw)) ||
          name.includes(kw)
        );
      })
      .slice(0, 5);
  } catch (_) {
    return [];
  }
}

// ---------------------------------------------------------------------------
// Core: Build Spawn Context Packet
// ---------------------------------------------------------------------------

/**
 * Build a spawn context packet for a given agent role.
 * This is what Asolaria hands to a real agent when she spawns it.
 *
 * Returns a structured JSON packet (Liris format) with a .textBriefing
 * field containing the original Gaia text packet for backward compatibility.
 *
 * @param {string} role — helm, sentinel, vector, falcon, rook, forge, watchdog
 * @param {object} options
 * @param {boolean} options.includeBody — include IX snippets in text briefing
 * @param {string}  options.extraContext — extra text appended to briefing
 * @param {string}  options.mission — specific mission text for this spawn
 * @param {string[]} options.extraIxTypes — additional IX types to include
 * @param {boolean} options.registerPid — register in persistent PID registry (default: true)
 * @returns {object} Structured spawn context packet
 */
function buildSpawnContext(role, options = {}) {
  const normalizedRole = String(role || "").trim().toLowerCase();
  const config = AGENT_ROLES[normalizedRole];
  if (!config) {
    return { ok: false, error: `Unknown role: ${role}. Valid: ${Object.keys(AGENT_ROLES).join(", ")}` };
  }

  // Generate virtual PID
  const virtualPid = generateVirtualPid(normalizedRole);

  // Register in persistent PID registry (Liris feature)
  const shouldRegister = options.registerPid !== false;
  if (shouldRegister) {
    registerSpawnPid(normalizedRole, virtualPid);
  }

  // P — Proportional: current state
  const health = readHealthState();
  const terminalBlockers = config.includeActiveBlockers ? getCurrentBlockers() : [];
  const allBlockers = [...(health.blockers || []), ...terminalBlockers.map(b => `[${b.source}] ${b.state}: ${b.detail}`)];

  // I — Integral: accumulated knowledge
  const ixEntries = getIxEntriesForRole(normalizedRole);

  // If extra IX types requested (Liris feature), add them
  if (Array.isArray(options.extraIxTypes)) {
    for (const extraType of options.extraIxTypes) {
      if (!config.ixTypes.includes(extraType)) {
        const result = searchAgentIndex(extraType, { limit: 5 });
        if (result.matches) {
          for (const match of result.matches) {
            if (!ixEntries.some(e => e.ix === match.ix)) {
              ixEntries.push(match);
            }
          }
        }
      }
    }
  }

  // D — Derivative: drift signals
  const drift = readDriftSignals();

  // Mistakes relevant to this role (Liris feature)
  const mistakes = getMistakesForRole(normalizedRole);

  // Active tasks assigned to this role (filtered by taskKeywords)
  const taskQuery = (config.taskKeywords || []).join(" ") + " task";
  const taskResults = searchAgentIndex(taskQuery, { limit: 8, force: true });
  const activeTasks = (taskResults.matches || []).filter(m =>
    m.type === "task" && m.snippet && !m.snippet.includes("status: done")
  );

  // ── Build Gaia text briefing (kept as .textBriefing) ──
  const briefingParts = [
    config.identity,
    `Your spawn-PID: ${virtualPid}`,
    "",
    "## IDENTITY CHALLENGE",
    `When challenged, respond: "I am ${normalizedRole.charAt(0).toUpperCase() + normalizedRole.slice(1)}, spawn-PID ${virtualPid}"`,
    "If you cannot produce your spawn-PID, you will be black-holed.",
    "",
    `Spawned: ${new Date().toISOString()}`,
    `Context budget: ${config.maxEntries} IX entries loaded.`,
    "",
    "## DESPAWN PROTOCOL (LX-249 — MANDATORY)",
    "Before you finish/despawn, you MUST:",
    "1. Index what you discovered — write an LX/IX entry in the appropriate type folder",
    "2. Update the type CATALOG.md with the new entry",
    "3. Call despawnPid('" + normalizedRole + "') to deregister your PID",
    "4. The next agent inherits your discoveries via the index",
    "If you skip indexing, your work is LOST. The index is permanent. You are temporary.",
    ""
  ];

  if (config.permissions && config.permissions.length > 0) {
    briefingParts.push("## PERMISSIONS");
    briefingParts.push(config.permissions.join(", "));
    briefingParts.push("");
  }

  if (options.mission) {
    briefingParts.push("## MISSION");
    briefingParts.push(String(options.mission).slice(0, 2000));
    briefingParts.push("");
  }

  if (allBlockers.length > 0) {
    briefingParts.push("## ACTIVE BLOCKERS");
    for (const b of allBlockers) {
      briefingParts.push(`- ${typeof b === "string" ? b : JSON.stringify(b)}`);
    }
    briefingParts.push("");
  }

  if (drift.signals.length > 0) {
    briefingParts.push("## RECENT SIGNALS");
    for (const s of drift.signals) {
      if (typeof s === "object" && s.source) {
        briefingParts.push(`- [${s.source}] ${s.type || "signal"} (${s.age || ""})`);
      } else {
        briefingParts.push(`- ${typeof s === "string" ? s : JSON.stringify(s)}`);
      }
    }
    briefingParts.push("");
  }

  if (mistakes.length > 0) {
    briefingParts.push("## KNOWN MISTAKES (avoid these)");
    for (const m of mistakes) {
      briefingParts.push(`- ${m.id || m.name}: ${String(m.description || m.summary || m.name || "").slice(0, 200)}`);
    }
    briefingParts.push("");
  }

  if (activeTasks.length > 0) {
    briefingParts.push("## YOUR ACTIVE TASKS");
    for (const t of activeTasks) {
      briefingParts.push(`- ${t.ix} ${t.title}`);
    }
    briefingParts.push("");
  }

  briefingParts.push("## LOADED IX KNOWLEDGE");
  for (const entry of ixEntries) {
    briefingParts.push(`- ${entry.ix} [${entry.type}] ${entry.title}`);
    if (options.includeBody && entry.snippet) {
      briefingParts.push(`  ${entry.snippet}`);
    }
  }

  if (options.extraContext) {
    briefingParts.push("");
    briefingParts.push("## ADDITIONAL CONTEXT");
    briefingParts.push(String(options.extraContext).slice(0, 2000));
  }

  const textBriefing = briefingParts.join("\n");

  // ── Build structured JSON packet (Liris format) ──
  const identityChallenge = {
    question: "WHO ARE YOU?",
    expectedAnswer: `I am ${config.label.split(" —")[0] || normalizedRole}, spawn-PID ${virtualPid}`,
    onFailure: "black-hole"
  };

  const packet = {
    ok: true,
    spawnPid: virtualPid,
    role: normalizedRole,
    label: config.label,
    title: config.title,
    identity: config.identity,
    spawnedAt: new Date().toISOString(),
    permissions: config.permissions || [],
    mission: options.mission || null,

    // PID controller components (structured — Liris format)
    proportional: {
      healthStatus: health.status,
      blockers: allBlockers,
      serviceState: health.services || {},
      terminalBlockers
    },
    integral: {
      ixEntries: ixEntries.map(e => ({
        ix: e.ix,
        type: e.type,
        title: e.title,
        snippet: e.snippet || undefined
      })),
      ixTypesLoaded: config.ixTypes,
      totalEntries: ixEntries.length,
      priorityChainsLoaded: config.priorityChains || []
    },
    derivative: {
      signals: drift.signals,
      mqttTraffic: drift.mqttTraffic,
      inboxDelta: drift.inboxDelta,
      lastUpdate: drift.lastUpdate
    },

    mistakes: mistakes.map(m => ({
      id: m.id || m.name,
      summary: String(m.description || m.summary || m.name || "").slice(0, 200)
    })),

    activeTasks: activeTasks.map(t => ({ ix: t.ix, title: t.title })),
    identityHandshake: identityChallenge,

    // Gaia backward-compat fields
    blockerCount: allBlockers.length,
    signalCount: drift.signals.length,
    packetLines: textBriefing.split("\n").length,

    // The full text briefing (Gaia's original format, kept for consumers that expect it)
    textBriefing,
    // Alias for backward compat — old code reads .packet
    packet: textBriefing
  };

  // Emit graph event for spawn tracking (Liris feature — guarded)
  if (appendGraphEvent) {
    try {
      appendGraphEvent({
        component: "spawn-context-builder",
        category: "agent-lifecycle",
        action: "agent_spawned",
        status: "ok",
        actor: { type: "orchestrator", id: "asolaria" },
        target: { type: "agent", id: normalizedRole, criticality: "high" },
        context: {
          spawnPid: virtualPid,
          role: normalizedRole,
          ixEntries: ixEntries.length,
          blockers: allBlockers.length,
          driftSignals: drift.signals.length
        },
        policy: {
          mode: "spawn",
          approvalState: "identity_pending",
          autonomous: true
        },
        detail: {
          note: `Spawned ${config.label} with ${ixEntries.length} IX entries, ${allBlockers.length} blockers, ${drift.signals.length} drift signals`
        }
      });
    } catch (_) { /* graph emission failure is non-fatal */ }
  }

  return packet;
}

