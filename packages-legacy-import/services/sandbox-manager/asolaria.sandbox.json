{
  "bind": "127.0.0.1",
  "port": 5443,
  "dockerImagePython": "python:3.11-slim",
  "dockerImageNode": "node:20-slim",
  "noNetworkDefault": true,
  "limits": {
    "cpus": 1,
    "memory": "256m",
    "pids": 64,
    "timeoutSeconds": 30,
    "maxCodeChars": 50000
  },
  "runtime": {
    "preferGVisor": false,
    "gVisorRuntimeName": "runsc"
  }
}
